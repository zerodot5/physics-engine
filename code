#importing required modules
import pyglet
import random
import math

#shortcuts for later uses 
from pyglet import shapes
from pyglet.window import key

#initializing the list of planets, gravity coefficient, and our timestep (also our pause toggle) (also also our focused planet index)
planets = []
planetIndex = 0

G = float(input("Enter the gravity coefficient (default is 2000): "))
dt = float(input("Enter the time step (default is 0.5): "))
tick = True

#mouse variables just in case
mouseX = 0
mouseY = 0

#camera variables
global cameraX
global cameraY
cameraX = 0
cameraY = 0

#zoom variable
global zoom
zoom = 1.0

#planetFocus mode
planetMode = False 
#i lowkey dont remember why i have this but im scared to get rid of it
i = 0

#initializing the window for pyglet
window = pyglet.window.Window(width=1280, height=720)

#shifting 0,0 to the center of the screen instead of the top left corner
centerX = window.width / 2
centerY = window.height / 2

#for grid background
grid_batch = pyglet.graphics.Batch()
grid_lines = []
GRID_SIZE = 50  # distance between grid lines

#planet class
class astralBody():

    def __init__(self, mass, radius, x, y, velocity, fixed):
        self.fixed = fixed
        #storing trail positions in world space instead of screen space so camera movement doesnt rotate them
        self.trailDots = []
        self.max_trail = 500
        self.vx = velocity
        self.vy = random.uniform(-2, 2)
        self.x = x 
        self.y = y 
        self.mass = mass
        self.radius = radius
        #no longer using a batch since trails are drawn manually each frame
        self.circle = shapes.Circle((x - cameraX) * zoom + centerX, (y - cameraY) * zoom + centerY, radius*zoom)
        self.color = (random.randint(0,255), random.randint(0,255), random.randint(0,255))
        self.circle.color = self.color

    def draw(self):
        #converting world position to screen position before drawing
        self.circle.x = (self.x - cameraX) * zoom + centerX
        self.circle.y = (self.y - cameraY) * zoom + centerY
        self.circle.draw()

        #converting each trail dot from world space to screen space every frame so they stay correct when camera moves
        for (wx, wy) in self.trailDots:
            sx = (wx - cameraX) * zoom + centerX
            sy = (wy - cameraY) * zoom + centerY
            dot = shapes.Circle(sx, sy, 1.5)
            dot.color = self.color
            dot.draw()

#for grid background
def create_grid():
    global grid_lines

    width, height = window.width, window.height

    # vertical lines
    x = 0
    while x < width:
        line = shapes.Line(x, 0, x, height, color=(40, 40, 40), batch=grid_batch)
        grid_lines.append(line)
        x += GRID_SIZE

    # horizontal lines
    y = 0
    while y < height:
        line = shapes.Line(0, y, width, y, color=(40, 40, 40), batch=grid_batch)
        grid_lines.append(line)
        y += GRID_SIZE

#for knowing where the planets will spawn
def draw_crosshair():
    size = 12 #for the lines
    color = (120, 120, 120)

    # horizontal line
    shapes.Line(
        mouseX - size, mouseY,
        mouseX + size, mouseY,
        color=color
    ).draw()

    # vertical line
    shapes.Line(
        mouseX, mouseY - size,
        mouseX, mouseY + size,
        color=color
    ).draw()

#to calculate and update velocities
def physicFunction():
    #checking if sim is paused
    if not tick:
        return
    #stored planets for deletion later
    to_remove = []

    #resetting the acceleration for each body
    for body in planets:
        body.ax = 0
        body.ay = 0

    for i in range(len(planets)):
        for j in range(i + 1, len(planets)):
            bodyA = planets[i]
            bodyB = planets[j]

            #calculating the distance between the two bodies
            dx = bodyB.x - bodyA.x
            dy = bodyB.y - bodyA.y
            #avoiding singularity
            distance = math.sqrt(dx**2 + dy**2)

            if distance == 0:
                continue

            if distance < bodyA.radius + bodyB.radius:
                
                #conserving momentums
                if not bodyA.fixed:
                    bodyA.vx = (bodyA.mass * bodyA.vx + bodyB.mass * bodyB.vx) / (bodyA.mass + bodyB.mass)
                    bodyA.vy = (bodyA.mass * bodyA.vy + bodyB.mass * bodyB.vy) / (bodyA.mass + bodyB.mass)
                if bodyA.mass > bodyB.mass:
                    #combining masses
                    bodyA.mass += bodyB.mass
                    #new radius with new mass
                    bodyA.radius = math.sqrt(bodyA.mass)
                    bodyA.circle.radius = bodyA.radius * zoom
                    #getting rid of old planet
                    to_remove.append(bodyB)
                    continue
            
            #normalizing the vector
            dx /= distance
            dy /= distance

            #gravity formula: F = G * (m1 * m2) / r^2
            force = (bodyA.mass * bodyB.mass) / (distance**2) * G #gravity coefficient

            #updating the acceleration using force and our normalized vector
            if not bodyA.fixed:
                bodyA.ax += force * dx / bodyA.mass
                bodyA.ay += force * dy / bodyA.mass
            if not bodyB.fixed:
                bodyB.ax -= force * dx / bodyB.mass
                bodyB.ay -= force * dy / bodyB.mass

    for body in to_remove:
        if body in planets:
            planets.remove(body)

    for body in planets:
        if not body.fixed:
            #velocity is acceleration times the time step variable
            body.vx += body.ax * dt
            body.vy += body.ay * dt

            #changing the position by velocity times the time step variable
            body.x += body.vx * dt 
            body.y += body.vy * dt 

        #actually changing the circle's position to match the new x and y
        body.circle.x = (body.x - cameraX) * zoom + centerX
        body.circle.y = (body.y - cameraY) * zoom + centerY

        #storing the world position of the trail dot instead of a screen space shape so it stays correct when the camera moves
        dot_world_pos = (body.x, body.y)
        if not body.fixed:
            body.trailDots.append(dot_world_pos)

        if len(body.trailDots) > body.max_trail:
            body.trailDots.pop(0)

#initializing the window and drawing the objects and labels
@window.event
def on_mouse_motion(x, y, dx, dy):
    global mouseX, mouseY
    mouseX = x
    mouseY = y

@window.event
def on_key_press(symbol, modifiers):
    global cameraX, cameraY
    global tick
    global zoom

    if symbol == key.SPACE:
        vx = float(input("Enter the initial velocity: "))
        tempMass = float(input("Enter the mass for your planet: "))
        planets.append(astralBody(tempMass, math.sqrt(tempMass), (mouseX - centerX) / zoom + cameraX, (mouseY - centerY) / zoom + cameraY, vx, False))
        print("added planet with mass " + str(tempMass) + " and velocity " + str(vx))
    if symbol == key.ENTER:
        tempMass = float(input("Enter the mass for your star: "))
        planets.append(astralBody(tempMass, math.sqrt(tempMass), (mouseX - centerX) / zoom + cameraX, (mouseY - centerY) / zoom + cameraY, 0, True))
        print("added star with mass " + str(tempMass))
    #focusing on planets 
    
    global planetMode
    global i 
    global planetIndex
    
    if symbol == key.TAB:
        planetMode = not planetMode
        if planetMode and len(planets) > 0:
            target = planets[planetIndex]
            cameraX = target.x
            cameraY = target.y
        print("planet focus mode", "enabled" if planetMode else "disabled")
        if not planetMode:
            #resetting camera to origin
            cameraX = 0
            cameraY = 0
            for planet in planets:
                planet.trailDots = []
                planet.circle.x = (planet.x - cameraX) * zoom + centerX 
                planet.circle.y = (planet.y - cameraY) * zoom + centerY

    if symbol == key.Q and planetMode and len(planets) > 0:
        #cycling to the previous planet
        planetIndex = (planetIndex - 1) % len(planets)
        for planet in planets:
            planet.trailDots = []
            planet.circle.x = (planet.x - cameraX) * zoom + centerX 
            planet.circle.y = (planet.y - cameraY) * zoom + centerY

    if symbol == key.E and planetMode and len(planets) > 0:
        #cycling to the next planet
        planetIndex = (planetIndex + 1) % len(planets)
        for planet in planets:
            planet.trailDots = []
            planet.circle.x = (planet.x - cameraX) * zoom + centerX 
            planet.circle.y = (planet.y - cameraY) * zoom + centerY

    if symbol == key.P:
        if tick:
            tick = False
            print("paused")
        else:
            tick = True
            print("resumed")
    if symbol == key.ESCAPE:
        window.close()
        print("exiting program")
    if symbol == key.C:
        planets.clear()
        print("cleared planets")
    if symbol == key.G:
        global G
        G = float(input("Enter the gravity coefficient (default is 2000): "))
        print("updated gravity coefficient to " + str(G))
    if symbol == key.T:
        global dt
        dt = float(input("Enter the time step (default is 0.5): "))
        print("updated time step to " + str(dt))
    if symbol == key.Z:
        zoom = zoom + 0.1
        for planet in planets:
            planet.circle.radius = planet.radius * zoom
            planet.trailDots = []
        for line in grid_lines:
            line.width = int(1 * zoom)
    if symbol == key.X:
        if zoom > 0.3:
            zoom = zoom - 0.1
            print(zoom)
            for planet in planets:
                planet.circle.radius = planet.radius * zoom
                planet.trailDots = []
            for line in grid_lines:
                line.width = int(1 * zoom)
    if symbol == key.LEFT:
        cameraX -= 20 / zoom
    if symbol == key.RIGHT:
        cameraX += 20 / zoom
    if symbol == key.UP:
        cameraY += 20 / zoom
    if symbol == key.DOWN:
        cameraY -= 20 / zoom

@window.event
#whenever a frame is drawn
def on_draw():
    global cameraX, cameraY

    window.clear()
    grid_batch.draw()

    physicFunction()

    #use the world position as the camera position
    if planetMode and len(planets) > 0:
        target = planets[planetIndex]
        cameraX = target.x
        cameraY = target.y

    draw_crosshair()
    for planet in planets:
        planet.draw()

#running the app
create_grid()
pyglet.app.run()
