#importing required modules
import pyglet
import random
import math

#shortcuts for later uses 
from pyglet import shapes
from pyglet.window import key

#initializing the list of planets, gravity coefficient, and our timestep (also our pause toggle)
planets = []

G = float(input("Enter the gravity coefficient (default is 2000): "))
dt = float(input("Enter the time step (default is 0.5): "))
tick = True

#stable mouse variables just in case
mouseX = 0
mouseY = 0

global cameraX
global cameraY
cameraX = 0
cameraY = 0

#zoom variable for later use
zoom = 1.0

#planetFocus mode
planetMode = False
i = 0

#initializing the window for pyglet
window = pyglet.window.Window(width=1280, height=720)

#shifting 0,0 to the center of the screen instead of the top left corner
centerX = window.width / 2
centerY = window.height / 2

#for grid background
grid_batch = pyglet.graphics.Batch()
grid_lines = []
GRID_SIZE = 50  # distance between grid lines

#planet class
class astralBody():

    def __init__(self, mass, radius, x, y, velocity, fixed):
        self.fixed = fixed
        self.batch = pyglet.graphics.Batch()
        self.trailDots = []
        self.max_trail = 500
        self.vx = velocity
        self.vy = random.uniform(-2, 2)
        self.x = x 
        self.y = y 
        self.mass = mass
        self.radius = radius
        self.circle = shapes.Circle(x + cameraX, y + cameraX, radius*zoom, batch=self.batch)
        self.color = (random.randint(0,255), random.randint(0,255), random.randint(0,255))
        self.circle.color = self.color

    def draw(self):
        self.batch.draw()

#for grid background
def create_grid():
    global grid_lines

    width, height = window.width, window.height

    # vertical lines
    x = 0
    while x < width:
        line = shapes.Line(x, 0, x, height, color=(40, 40, 40), batch=grid_batch)
        grid_lines.append(line)
        x += GRID_SIZE

    # horizontal lines
    y = 0
    while y < height:
        line = shapes.Line(0, y, width, y, color=(40, 40, 40), batch=grid_batch)
        grid_lines.append(line)
        y += GRID_SIZE

#for knowing where the planets will spawn
def draw_crosshair():
    size = 12 #for the lines
    color = (120, 120, 120)

    # horizontal line
    shapes.Line(
        mouseX - size, mouseY,
        mouseX + size, mouseY,
        color=color
    ).draw()

    # vertical line
    shapes.Line(
        mouseX, mouseY - size,
        mouseX, mouseY + size,
        color=color
    ).draw()

#to calculate and update velocities
def physicFunction():
    #checking if sim is paused
    if not tick:
        return
    #stored planets for deletion later
    to_remove = []

    #resetting the acceleration for each body
    for body in planets:
        body.ax = 0
        body.ay = 0

    for i in range(len(planets)):
        for j in range(i + 1, len(planets)):
            bodyA = planets[i]
            bodyB = planets[j]

            #calculating the distance between the two bodies
            dx = bodyB.x - bodyA.x
            dy = bodyB.y - bodyA.y
            #avoiding singularity
            distance = math.sqrt(dx**2 + dy**2)


            if distance == 0:
                continue

            if distance < bodyA.radius + bodyB.radius:
                
                #conserving momentums
                if not bodyA.fixed:
                    bodyA.vx = (bodyA.mass * bodyA.vx + bodyB.mass * bodyB.vx) / (bodyA.mass + bodyB.mass)
                    bodyA.vy = (bodyA.mass * bodyA.vy + bodyB.mass * bodyB.vy) / (bodyA.mass + bodyB.mass)
                if bodyA.mass > bodyB.mass:
                    #combining masses
                    bodyA.mass += bodyB.mass
                    #new radius with new mass
                    bodyA.radius = math.sqrt(bodyA.mass)
                    bodyA.circle.radius = bodyA.radius * zoom
                    #getting rid of old planet
                    to_remove.append(bodyB)
                    continue
            
            #normalizing the vector
            dx /= distance
            dy /= distance

            #gravity formula: F = G * (m1 * m2) / r^2
            force = (bodyA.mass * bodyB.mass) / (distance**2) * G #gravity coefficient

            #updating the acceleration using force and our normalized vector
            if not bodyA.fixed:
                bodyA.ax += force * dx / bodyA.mass
                bodyA.ay += force * dy / bodyA.mass
            if not bodyB.fixed:
                bodyB.ax -= force * dx / bodyB.mass
                bodyB.ay -= force * dy / bodyB.mass

    for body in to_remove:
                if body in planets:
                    planets.remove(body)

    for body in planets:
        if not body.fixed:
            #velocity is acceleration times the time step variable
            body.vx += body.ax * dt
            body.vy += body.ay * dt

            #changing the position by velocity times the time step variable
            body.x += body.vx * dt 
            body.y += body.vy * dt 

            #actually changing the circle's position to match the new x and y
            body.circle.x = (body.x - cameraX - centerX) * zoom + centerX 
            body.circle.y = (body.y - cameraY - centerY) * zoom + centerY

        dot = shapes.Circle((body.x - centerX + cameraX) * zoom + centerX, (body.y - centerY + cameraY) * zoom + centerY,1.5,batch=body.batch)   
        dot.color = body.color
        if not body.fixed:
            body.trailDots.append(dot)

        if len(body.trailDots) > body.max_trail:
            old = body.trailDots.pop(0)
            old.delete()

#initializing the window and drawing the objects and labels
@window.event
def on_mouse_motion(x, y, dx, dy):
    global mouseX, mouseY
    mouseX = x
    mouseY = y

@window.event
def on_key_press(symbol, modifiers):
    global cameraX, cameraY
    global tick;
    if symbol == key.SPACE:
        vx = float(input("Enter the initial velocity: "))
        tempMass = float(input("Enter the mass for your planet: "))
        planets.append(astralBody(tempMass, math.sqrt(tempMass), mouseX, mouseY, vx, False))
        print("added planet with mass " + str(tempMass) + " and velocity " + str(vx))
    if symbol == key.ENTER:
        tempMass = float(input("Enter the mass for your star: "))
        planets.append(astralBody(tempMass, math.sqrt(tempMass), mouseX, mouseY, 0, True))
        print("added star with mass " + str(tempMass))
    #focusing on planets 
    
    global planetMode
    global i 

    if symbol == key.TAB:
        
        
        planetMode = not planetMode
        if planetMode:
            print("planet focus mode enabled")
        if not planetMode:
            print("planet focus mode disabled")
        print(planets)
        while planetMode:
            target = planets[i]
            cameraX = target.x - centerX
            cameraY = target.y - centerY
            print(cameraX, cameraY)
            
    if symbol == key.Q:
        if planetMode:
            i =+ 1
    if symbol == key.E:
        if planetMode:
            i =- 1
           
        
        

    if symbol == key.P:
        if tick:
            tick = False
            print("paused")
        else:
            tick = True
            print("resumed")
    if symbol == key.ESCAPE:
        window.close()
        print("exiting program")
    if symbol == key.C:
        planets.clear()
        print("cleared planets")
    if symbol == key.G:
        global G
        G = float(input("Enter the gravity coefficient (default is 2000): "))
        print("updated gravity coefficient to " + str(G))
    if symbol == key.T:
        global dt
        dt = float(input("Enter the time step (default is 0.5): "))
        print("updated time step to " + str(dt))
    global zoom
    if symbol == key.Z:
        zoom = zoom + 0.1
        for planet in planets:
            planet.circle.radius = planet.radius * zoom
            planet.trailDots = []
        for line in grid_lines:
            line.width = int(1 * zoom)
    if symbol == key.X:
        if zoom > 0.3:
            zoom = zoom - 0.1
            print(zoom)
            for planet in planets:
                planet.circle.radius = planet.radius * zoom
                planet.trailDots = []
            for line in grid_lines:
                line.width = int(1 * zoom)
    if symbol == key.LEFT:
        cameraX += 20
        for planet in planets:
            planet.trailDots = []
            planet.circle.x = (planet.x - centerX) * zoom + centerX + cameraX
            planet.circle.y = (planet.y - centerY) * zoom + centerY + cameraY
    if symbol == key.RIGHT:
        cameraX -= 20
        for planet in planets:
            planet.trailDots = []
            planet.circle.x = (planet.x - centerX) * zoom + centerX + cameraX
            planet.circle.y = (planet.y - centerY) * zoom + centerY + cameraY
    if symbol == key.UP:
        cameraY -= 20
        for planet in planets:
            planet.trailDots = []
            planet.circle.x = (planet.x - centerX) * zoom + centerX + cameraX
            planet.circle.y = (planet.y - centerY) * zoom + centerY + cameraY
    if symbol == key.DOWN:
        cameraY += 20
        for planet in planets:
            planet.trailDots = []
            planet.circle.x = (planet.x - centerX) * zoom + centerX + cameraX
            planet.circle.y = (planet.y - centerY) * zoom + centerY + cameraY


@window.event
#whenever a frame is drawn
def on_draw():
    window.clear()
    grid_batch.draw()
    physicFunction()
    draw_crosshair()
    for planet in planets:
        planet.draw()

#running the app
create_grid()
pyglet.app.run()
